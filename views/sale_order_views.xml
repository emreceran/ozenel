<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_ozenel" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.ozenel</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list/field[@name='product_uom_qty']" position="after">
                <field name="tedarikci_fiyat" string="Tedarikçi Fiyatı" optional="show"/>
                <field name="tedarikci_fiyat_indirim_yuzdesi" string="İndirim (%)" optional="show"/>
                <field name="tedarikci_fiyat_indirimli_maliyet" string="İndirimli Maliyet" readonly="1" optional="show"/>
            </xpath>

            </field>
    </record>
</odoo>